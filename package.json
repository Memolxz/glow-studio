{
  "name": "glow-studio",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "tsx --watch src/index.ts",
    "db:migrate": "prisma migrate dev --schema src/db/schema",
    "db:generate": "prisma generate --no-engine --schema src/db/schema"
  },
  "packageManager": "pnpm@10.8.1",
  "type": "module",
  "private": "true",
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "dotenv": "^16.5.0",
    "express": "5.1.0",
    "node-cron": "^4.0.7"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.14.0",
    "prisma": "^6.7.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "schema": "src/db/schema"
  }
}
