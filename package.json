{
  "name": "glow-studio",
  "version": "1.0.0",
  "description": "Projecto API web para la materia Practicas Profecionalizantes",
  "main": "index.js",
  "scripts": {
    "serve": "concurrently \"pnpm tsc -w\" \"node --watch dist/index.js\"",
    "build": "rimraf dist && pnpm tsc",
    "start": "node dist/index.js",
    "clean": "rimraf dist", 
    "db:migrate": "prisma migrate dev --schema src/db/schema",
    "db:generate": "prisma generate --no-engine --schema src/db/schema"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Memolxz/glow-studio.git"
  },
  "bugs": {
    "url": "https://github.com/Memolxz/glow-studio/issues"
  },
  "packageManager": "pnpm@10.8.1",
  "type": "commonjs",
  "private": true,
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "dotenv": "^16.5.0",
    "express": "5.1.0",
    "node-cron": "^4.0.7"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.14.0",
    "concurrently": "^9.1.2",
    "prisma": "^6.7.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "schema": "src/db/schema"
  }
}
